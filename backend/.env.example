NODE_ENV=development
PORT=3001

# ─── MongoDB Atlas ────────────────────────────────────────────
MONGO_URI=mongodb+srv://<usuario>:<senha>@cluster0.xxxx.mongodb.net/al-sistemas?retryWrites=true&w=majority

# ─── Cloudinary ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── JWT ──────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 64
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ─── Admin padrão (usado pelo seed.js) ────────────────────────
ADMIN_EMAIL=admin@al-sistemas.com
ADMIN_SENHA=

# ─── GitHub Module ────────────────────────────────────────────
# Token: Personal Access Token (fine-grained recomendado)
GITHUB_TOKEN=
GITHUB_USER=
GITHUB_ORG=

# ─── Projetos Locais ──────────────────────────────────────────
# Deixar vazio: resolve automaticamente para ../projetos
# PROJETOS_PATH=

# ─── IA Assistant ─────────────────────────────────────────────
# Provedor ativo: 'groq' (padrão, rápido e gratuito) ou 'anthropic' (legacy)
AI_PROVIDER=groq

# Groq — obter em https://console.groq.com
GROQ_API_KEY=
# Modelo Groq (padrão: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic — obter em https://console.anthropic.com (só necessário se AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# Modelo Anthropic (padrão: claude-opus-4-6)
# ANTHROPIC_MODEL=claude-opus-4-6

# Limite de tokens por resposta da IA (padrão: 1000)
AI_MAX_TOKENS=1000

# ─── Redis (opcional) ─────────────────────────────────────────
# Fallback automático para in-memory se não configurado
REDIS_URL=redis://localhost:6379

# ─── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=https://alsistemas.vercel.app

# ─── Métricas Prometheus (opcional) ──────────────────────────
# METRICS_TOKEN=
