# ─── Backend URL ─────────────────────────────────────────────
# Desenvolvimento: http://localhost:3001/api
# Produção (Render): https://SEU-BACKEND.onrender.com/api
VITE_API_URL=https://SEU-BACKEND.onrender.com/api

# ─── Identidade visual ───────────────────────────────────────
VITE_APP_NAME=AL Sistemas
VITE_APP_TAGLINE=Painel de Gerenciamento
VITE_APP_VERSION=2.0.0
VITE_APP_ENV=production

# ─── Feature Flags ───────────────────────────────────────────
# true → módulo Portal aparece na navegação
VITE_MODULE_PORTAL=true
# true → módulo GitHub aparece na navegação
VITE_MODULE_GITHUB=true
